# ───────────────────────────────────────────────────────────────────────────
# InboxSweep environment variables
# Copy this file to `.env` for local dev, and set the same keys in the Netlify
# dashboard (Site settings → Environment variables) for production.
# ───────────────────────────────────────────────────────────────────────────

# Google OAuth client ID. SAFE to expose in the browser. Used by both the
# frontend (must be prefixed VITE_) and the serverless functions.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google OAuth client secret. SERVER-SIDE ONLY. Never prefix this with VITE_
# and never reference it from /src — it must stay out of the client bundle.
GOOGLE_CLIENT_SECRET=your-client-secret

# The redirect URI registered in Google Cloud Console. Must match exactly.
# Local:  http://localhost:8888/app
# Prod:   https://your-site.netlify.app/app
OAUTH_REDIRECT_URI=http://localhost:8888/app
VITE_OAUTH_REDIRECT_URI=http://localhost:8888/app

# Origin allowed to call the serverless functions (CORS + CSRF origin check).
# Local:  http://localhost:8888
# Prod:   https://your-site.netlify.app
ALLOWED_ORIGIN=http://localhost:8888
